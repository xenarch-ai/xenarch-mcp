{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.xenarch-ai/xenarch-mcp",
  "description": "Xenarch — x402 MCP server for AI agent payments. Non-custodial, USDC on Base L2.",
  "websiteUrl": "https://xenarch.com",
  "repository": {
    "url": "https://github.com/xenarch-ai/xenarch-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@xenarch/agent-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Wallet private key (hex, 0x-prefixed). Auto-generates on first run if omitted.",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "XENARCH_PRIVATE_KEY"
        },
        {
          "description": "Base RPC endpoint URL",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "XENARCH_RPC_URL"
        },
        {
          "description": "Network for payments (base or base-sepolia)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "XENARCH_NETWORK"
        },
        {
          "description": "Max USD per call to auto-approve without prompting",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "XENARCH_MAX_PAYMENT_USD"
        }
      ]
    },
    {
      "registryType": "npm",
      "identifier": "@xenarch/agent-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "streamable-http",
        "url": "https://mcp.xenarch.dev/mcp"
      },
      "environmentVariables": [
        {
          "description": "Wallet private key (hex, 0x-prefixed). Auto-generates on first run if omitted.",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "XENARCH_PRIVATE_KEY"
        },
        {
          "description": "Base RPC endpoint URL",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "XENARCH_RPC_URL"
        },
        {
          "description": "Network for payments (base or base-sepolia)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "XENARCH_NETWORK"
        },
        {
          "description": "Max USD per call to auto-approve without prompting",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "XENARCH_MAX_PAYMENT_USD"
        },
        {
          "description": "Port for HTTP server (default: 3000)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "PORT"
        },
        {
          "description": "Set to 'http' to enable HTTP transport",
          "isRequired": true,
          "format": "string",
          "isSecret": false,
          "name": "TRANSPORT"
        }
      ]
    }
  ]
}
